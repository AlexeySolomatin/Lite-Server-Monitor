#!/usr/bin/env bash
#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# Main CLI Executable
# -----------------------------------------------------------------------------

set -Eeuo pipefail

# Определение рабочей директории
LSM_ROOT="${LSM_ROOT:-/opt/lsm}"
export LSM_ROOT

# Подключение базовых библиотек
if [[ -f "${LSM_ROOT}/lib/core/common.sh" ]]; then
    source "${LSM_ROOT}/lib/core/common.sh"
fi

if [[ -f "${LSM_ROOT}/lib/core/ui.sh" ]]; then
    source "${LSM_ROOT}/lib/core/ui.sh"
fi

# Извлечение команды и оставшихся аргументов
COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
    shift
fi

COMMAND_SCRIPT="${LSM_ROOT}/commands/${COMMAND}.sh"

# Маршрутизация выполнения
if [[ -f "${COMMAND_SCRIPT}" ]]; then
    exec bash "${COMMAND_SCRIPT}" "$@"
else
    if declare -f log_error >/dev/null 2>&1; then
        log_error "Unknown command: '${COMMAND}'"
    else
        echo "Error: Unknown command '${COMMAND}'" >&2
    fi
    echo ""
    exec bash "${LSM_ROOT}/commands/help.sh"
fi
