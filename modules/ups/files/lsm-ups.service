#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# UPS Monitor Service
# -----------------------------------------------------------------------------

[Unit]

Description=Lite Server Monitor - UPS Monitor
Documentation=https://github.com/AlexeySolomatin/Lite-Server-Monitor

After=apcupsd.service



[Service]

Type=oneshot

ExecStart=/opt/lsm/modules/ups/check_ups.sh


User=root
Group=root


NoNewPrivileges=true

PrivateTmp=true

ProtectSystem=strict
ProtectHome=true


ReadWritePaths=/var/lib/lsm /var/log/lsm



[Install]

WantedBy=multi-user.target
