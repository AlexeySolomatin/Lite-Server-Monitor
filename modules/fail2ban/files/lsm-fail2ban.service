#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# Fail2Ban Monitor Service
# -----------------------------------------------------------------------------

[Unit]

Description=Lite Server Monitor - Fail2Ban Monitor
Documentation=https://github.com/AlexeySolomatin/Lite-Server-Monitor


[Service]

Type=oneshot

ExecStart=/opt/lsm/modules/fail2ban/check_fail2ban.sh

User=root
Group=root


NoNewPrivileges=true

PrivateTmp=true

ProtectSystem=strict
ProtectHome=true

ReadWritePaths=/var/lib/lsm /var/log/lsm


[Install]

WantedBy=multi-user.target
