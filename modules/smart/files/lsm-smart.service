#
# -----------------------------------------------------------------------------
# Lite Server Monitor (LSM)
# SMART Monitor Service
# -----------------------------------------------------------------------------

[Unit]
Description=Lite Server Monitor - SMART Monitor
Documentation=https://github.com/AlexeySolomatin/Lite-Server-Monitor

[Service]
Type=oneshot

ExecStart=/opt/lsm/modules/smart/check_smart.sh

User=root
Group=root

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/lsm /var/log/lsm

Nice=10
